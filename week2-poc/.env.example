# EPAM Dial (OpenAI-compatible) access — all four are required.
# Copy to .env and fill in; .env is gitignored and never committed (Principle VII).
DIAL_BASE_URL=https://your-dial-instance.example.com
DIAL_API_KEY=your-api-key
DIAL_CHAT_MODEL=gpt-4o
DIAL_EMBEDDING_MODEL=text-embedding-3-small

# Optional overrides (defaults shown).
# RAG_K — number of chunks retrieved per question.
#RAG_K=5
# REFUSAL_MIN_SCORE — cosine-similarity floor below which the assistant refuses
# (FR-004). Provisional default; calibrated against the refusal group of the
# golden set (task T037).
#REFUSAL_MIN_SCORE=0.25
